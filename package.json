{
  "name": "webhook-test-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-http-header-size=65536 vinext dev",
    "build": "vinext build && node ./scripts/fix-vinext-dist-imports.cjs",
    "start": "cross-env NODE_OPTIONS=--max-http-header-size=65536 vinext start",
    "dev:next": "next dev",
    "build:next": "next build",
    "start:next": "next start",
    "lint": "eslint",
    "db:migrate:local": "wrangler --config d1.wrangler.jsonc d1 migrations apply webhook-test-db --local",
    "db:migrate:remote": "wrangler --config d1.wrangler.jsonc d1 migrations apply webhook-test-db --remote",
    "cf-types": "wrangler types --config wrangler.jsonc",
    "deploy:workers": "pnpm run build && pnpm exec wrangler deploy",
    "deploy:workers:preview": "pnpm run build && pnpm exec wrangler deploy --env preview",
    "test:r2": "node ./scripts/test-r2-connection.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-resizable-panels": "^4.9.0",
    "recharts": "3.8.0",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "vinext": "^0.0.39",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-rsc": "^0.5.21",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "react-server-dom-webpack": "^19.2.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "8.0.3",
    "wrangler": "^4.80.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "vinext@0.0.39": "patches/vinext@0.0.39.patch"
    }
  },
  "type": "module"
}
