# Cloudflare — ใช้กับ Wrangler / vinext deploy / test:r2
# Copy เป็น .env แล้วกรอกค่าจริง (อย่า commit .env)
CLOUDFLARE_ACCOUNT_ID=
# Optional — ถ้าใช้ wrangler login (OAuth) แล้ว ให้เว้นว่างหรือคอมเมนต์บรรทัดนี้ระหว่าง login
# Wrangler/Vinext โหลดค่าจากไฟล์ .env ดังนั้นแค่ unset ในเชลล์ไม่ได้ตัด token ออก
# ต้องมี Account → Workers Scripts → Edit (+ บางครั้ง User → Memberships Read ถ้าไม่ใช้ OAuth)
CLOUDFLARE_API_TOKEN=

# R2 (optional — ถ้าใช้สคริปต์ test:r2 หรือ S3 API ภายหลัง)
R2_ACCOUNT_ID=
R2_API_TOKEN=
R2_BUCKET_NAME=
R2_BUCKET_URL=
